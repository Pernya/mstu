@startuml
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ArrowColor #1F2933
left to right direction

actor "Аналитик" as Analyst

package "Источник" {
  cloud "Официальный датасет\nMontgomery County" as Source
}

package "Оркестрация ETL" {
  component "Airflow Webserver" as Web
  component "DAG продаж" as Dag
  component "Python-модули пайплайна" as Modules
}

package "Хранилище PostgreSQL" {
  database "raw\nисходные строки" as Raw
  database "dv\nData Vault" as Vault
  database "mart\nвитрины" as Mart
  database "ml\nпрогноз и сегменты" as Ml
}

package "Аналитика и ML" {
  component "EDA и графики" as Eda
  component "Прогноз продаж" as Forecast
  component "Кластеризация поставщиков" as Clusters
  component "Отчеты" as Reports
}

package "BI-слой" {
  component "Apache Superset" as Superset
  component "Дашборды продаж" as Dashboards
}

package "Инфраструктура" {
  node "docker-compose.etl.yml" as EtlCompose
  node "docker-compose.superset.yml" as SupersetCompose
  node "PostgreSQL контейнер" as Postgres
  node "Airflow контейнеры" as Airflow
  node "Superset контейнер" as SupersetNode
}

Analyst --> Web : запускает DAG
Analyst --> Dashboards : анализирует показатели
Web --> Dag : управляет запуском
Dag --> Modules : выполняет задачи
Modules --> Source : читает API
Modules --> Raw : записывает нормализованные строки
Raw --> Vault : формирует hubs, links, satellites
Vault --> Mart : питает витрины
Mart --> Eda : дает агрегаты
Mart --> Forecast : дает признаки
Mart --> Clusters : дает сегменты
Forecast --> Ml : сохраняет прогноз
Clusters --> Ml : сохраняет портреты
Eda --> Reports : сохраняет графики
Forecast --> Reports : сохраняет метрики
Clusters --> Reports : сохраняет рекомендации
Superset --> Mart : читает через host.docker.internal
Superset --> Ml : читает прогноз и сегменты
Superset --> Dashboards : строит визуализации
EtlCompose *-- Airflow
EtlCompose *-- Postgres
SupersetCompose *-- SupersetNode
Postgres --> Raw
Postgres --> Vault
Postgres --> Mart
Postgres --> Ml
Airflow --> Web
SupersetNode --> Superset

@enduml
